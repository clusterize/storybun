{
  "name": "storybun",
  "version": "0.1.0",
  "description": "A visual regression testing tool made for Bun",
  "type": "module",
  "bin": { "storybun": "./src/cli.ts" },
  "exports": {
    ".": "./src/index.ts",
    "./ui": "./src/ui/index.tsx",
    "./ui/styles.css": "./src/ui/styles.css"
  },
  "dependencies": {
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0"
  },
  "peerDependencies": {
    "playwright": "^1.40.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pngjs": "^6.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.50.0",
    "react": "^19",
    "react-dom": "^19"
  }
}
